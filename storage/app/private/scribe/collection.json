    },
    "item": [
        {
            "name": "Authentication",
            "description": "",
            "item": [
                {
                    "name": "Login (pedagog \/ admin)",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/auth\/login",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/auth\/login"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"arjan.hoxha@uamd.edu.al\",\"password\":\"secret123\"}"
                        },
                        "description": "Returns a Sanctum token for pedagog and admin users.\nStudents must use the Google OAuth flow instead.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"data\": {\"user\": {\"id\": 1, \"name\": \"Arjan Hoxha\", \"email\": \"arjan@uamd.edu.al\", \"role\": \"pedagog\"}, \"token\": \"1|abc...\"},\n  \"message\": \"Hyrja u krye me sukses.\",\n  \"status\": 200\n}",
                            "name": "Success"
                        },
                        {
                            "header": [],
                            "code": 401,
                            "body": "{\"data\": null, \"message\": \"Email ose fjal\\u00ebkalimi i gab\\u00fear.\", \"status\": 401}",
                            "name": "Wrong credentials"
                        },
                        {
                            "header": [],
                            "code": 403,
                            "body": "{\"data\": null, \"message\": \"Studen\\u00ebt\u00ebt p\\u00ebrdorin Google.\", \"status\": 403}",
                            "name": "Student tried email login"
                        }
                    ]
                },
                {
                    "name": "Google OAuth \u2014 redirect",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/auth\/google\/redirect",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/auth\/google\/redirect"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Redirects the browser to Google's consent screen.\nOpen this URL directly in the browser; **do not** call it via fetch\/axios.\nOnly @students.uamd.edu.al accounts are accepted.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [
                                {
                                    "key": "cache-control",
                                    "value": "no-cache, private"
                                },
                                {
                                    "key": "location",
                                    "value": "https:\/\/accounts.google.com\/o\/oauth2\/auth?client_id=&redirect_uri=http%3A%2F%2F127.0.0.1%3A8000%2Fapi%2Fv1%2Fauth%2Fgoogle%2Fcallback&scope=openid+profile+email&response_type=code&hd=students.uamd.edu.al"
                                },
                                {
                                    "key": "content-type",
                                    "value": "text\/html; charset=utf-8"
                                },
                                {
                                    "key": "vary",
                                    "value": "Origin"
                                }
                            ],
                            "code": 302,
                            "body": "<!DOCTYPE html>\n<html>\n    <head>\n        <meta charset=\"UTF-8\" \/>\n        <meta http-equiv=\"refresh\" content=\"0;url='https:\/\/accounts.google.com\/o\/oauth2\/auth?client_id=&amp;redirect_uri=http%3A%2F%2F127.0.0.1%3A8000%2Fapi%2Fv1%2Fauth%2Fgoogle%2Fcallback&amp;scope=openid+profile+email&amp;response_type=code&amp;hd=students.uamd.edu.al'\" \/>\n\n        <title>Redirecting to https:\/\/accounts.google.com\/o\/oauth2\/auth?client_id=&amp;redirect_uri=http%3A%2F%2F127.0.0.1%3A8000%2Fapi%2Fv1%2Fauth%2Fgoogle%2Fcallback&amp;scope=openid+profile+email&amp;response_type=code&amp;hd=students.uamd.edu.al<\/title>\n    <\/head>\n    <body>\n        Redirecting to <a href=\"https:\/\/accounts.google.com\/o\/oauth2\/auth?client_id=&amp;redirect_uri=http%3A%2F%2F127.0.0.1%3A8000%2Fapi%2Fv1%2Fauth%2Fgoogle%2Fcallback&amp;scope=openid+profile+email&amp;response_type=code&amp;hd=students.uamd.edu.al\">https:\/\/accounts.google.com\/o\/oauth2\/auth?client_id=&amp;redirect_uri=http%3A%2F%2F127.0.0.1%3A8000%2Fapi%2Fv1%2Fauth%2Fgoogle%2Fcallback&amp;scope=openid+profile+email&amp;response_type=code&amp;hd=students.uamd.edu.al<\/a>.\n    <\/body>\n<\/html>",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Google OAuth \u2014 callback",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/auth\/google\/callback",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/auth\/google\/callback"
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Handles Google's redirect back. Verifies the `@students.uamd.edu.al` domain,\ncreates or retrieves the user, and returns a Sanctum token.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"data\": {\"user\": {\"id\": 5, \"name\": \"Ana Koci\", \"email\": \"a.koci@students.uamd.edu.al\", \"role\": \"student\"}, \"token\": \"2|xyz...\"},\n  \"message\": \"Hyrja me Google u krye me sukses.\",\n  \"status\": 200\n}",
                            "name": ""
                        },
                        {
                            "header": [],
                            "code": 403,
                            "body": "{\"data\": null, \"message\": \"Vet\\u00ebm student\\u00ebt e UAMD...\", \"status\": 403}",
                            "name": ""
                        }
                    ]
                },
                {
                    "name": "Get authenticated user",
                    "request": {
                        "url": {
