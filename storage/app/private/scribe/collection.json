                            "body": "{\n  \"data\": {\"id\": 1, \"name\": \"Arjan Hoxha\", \"email\": \"arjan@uamd.edu.al\", \"role\": \"pedagog\", \"avatarUrl\": null},\n  \"message\": \"OK\",\n  \"status\": 200\n}",
                            "name": ""
                        }
                    ]
                },
